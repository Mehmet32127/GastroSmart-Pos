# GastroSmart Frontend — Environment Variables
# Kopyalayın: copy .env.example .env.local

# ⚠️ NOT: VITE_API_URL ve VITE_SOCKET_URL satırlarını YORUM SATIRINDA bırakın!
# Sistem otomatik olarak sayfanın açıldığı adresi kullanır.
# Bunları ayarlarsanız tablet/LAN bağlantısı çalışmaz.
# VITE_API_URL=http://192.168.1.100:3001    ← KULLANMAYIN
# VITE_SOCKET_URL=http://192.168.1.100:3001 ← KULLANMAYIN

# ⚠️ KRITIK: Backend .env içindeki HMAC_SECRET ile AYNI olmali!
VITE_HMAC_SECRET=gastrosmart-offline-queue-secret-change-me
