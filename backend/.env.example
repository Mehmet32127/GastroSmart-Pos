# GastroSmart Backend — Ortam Değişkenleri
# Kopyala: copy .env.example .env  (sonra değerleri doldur)

# ── Sunucu ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# ── JWT Secrets (MUTLAKA DEĞİŞTİRİN!) ────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Offline Queue HMAC ────────────────────────────────────────────────────────
# ⚠️ KRİTİK: frontend/.env.local içindeki VITE_HMAC_SECRET ile AYNI olmalı!
HMAC_SECRET=your-hmac-secret-key-change-me

# ── CORS ──────────────────────────────────────────────────────────────────────
# Tablet ve cihazların IP adreslerini buraya ekleyin
CORS_ORIGINS=http://localhost:3001,http://192.168.1.100:3001

# ── Veritabanı ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/gastrosmart

# ── Dosya Yükleme ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ── Güvenlik ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# ── Restoran ──────────────────────────────────────────────────────────────────
RESTAURANT_NAME=Restoranım

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ── Yedekleme ─────────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_SCHEDULE=0 23 * * *
BACKUP_RETENTION_DAYS=30

# ── İzleme ────────────────────────────────────────────────────────────────────
MONITOR_ENABLED=true
MEMORY_USAGE_THRESHOLD=80

# ── SSL (opsiyonel, LAN'da gerek yok) ────────────────────────────────────────
# SSL_CERT=./certs/cert.pem
# SSL_KEY=./certs/key.pem
