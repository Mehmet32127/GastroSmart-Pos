{
  "name": "gastrosmart-pos",
  "version": "1.0.0",
  "description": "Profesyonel Restoran Adisyon Sistemi",
  "main": "electron/main.js",
  "author": "GastroSmart",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.gastrosmart.pos",
    "productName": "GastroSmart POS",
    "copyright": "GastroSmart",
    "asar": true,
    "asarUnpack": [
      "**/mongodb/**"
    ],
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "electron/loading.html"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/.cache/**",
          "!logs/**",
          "!uploads/**",
          "!backups/**",
          "!.env",
          "!data/**"
        ]
      },
      {
        "from": "electron/mongodb",
        "to": "mongodb"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GastroSmart POS",
      "runAfterFinish": true
    }
  }
}
